#!/usr/bin/env bun

// Preview markdown files in the browser with GitHub-style styling and live reload.
// Usage: md-preview [--debug] <markdown-file>
//   --debug: Output HTML to stdout instead of opening browser

import { basename, resolve } from "path";
import { watch } from "fs";
import MarkdownIt from "markdown-it";
import hljs from "highlight.js";

const args = process.argv.slice(2);
let debug = false;
if (args[0] === "--debug") {
  debug = true;
  args.shift();
}

if (args.length < 1) {
  console.error("Usage: md-preview [--debug] <markdown-file>");
  process.exit(1);
}

const mdFile = resolve(args[0]);

// GitHub dark theme CSS
const githubCss = `
.markdown-body {
  color: #c9d1d9;
  background-color: #0d1117;
  font-family: -apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans",Helvetica,Arial,sans-serif,"Apple Color Emoji","Segoe UI Emoji";
  font-size: 16px;
  line-height: 1.5;
  word-wrap: break-word;
}
.markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4,
.markdown-body h5, .markdown-body h6 { margin-top: 24px; margin-bottom: 16px; font-weight: 600; line-height: 1.25; color: #f0f6fc; border-bottom: 1px solid #21262d; padding-bottom: 0.3em; }
.markdown-body h1 { font-size: 2em; padding-bottom: 0.3em; border-bottom: 1px solid #21262d; }
.markdown-body h2 { font-size: 1.5em; padding-bottom: 0.3em; border-bottom: 1px solid #21262d; }
.markdown-body h3 { font-size: 1.25em; }
.markdown-body h4 { font-size: 1em; }
.markdown-body p { margin-top: 0; margin-bottom: 16px; }
.markdown-body code { padding: 0.2em 0.4em; margin: 0; font-size: 85%; background-color: rgba(110,118,129,0.4); border-radius: 6px; font-family: ui-monospace,SFMono-Regular,"SF Mono",Menlo,Consolas,"Liberation Mono",monospace; }
.markdown-body pre { padding: 16px; overflow: auto; font-size: 85%; line-height: 1.45; background-color: #161b22; border-radius: 6px; white-space: pre; }
.markdown-body pre code { padding: 0; margin: 0; background-color: transparent; border-radius: 0; display: inline; }
.markdown-body pre > code { display: block; }
.markdown-body blockquote { margin: 0; padding: 0 1em; color: #8b949e; border-left: 0.25em solid #30363d; }
.markdown-body ul, .markdown-body ol { margin-top: 0; margin-bottom: 16px; padding-left: 2em; }
.markdown-body li + li { margin-top: 0.25em; }
.markdown-body hr { height: 0.25em; padding: 0; margin: 24px 0; background-color: #21262d; border: 0; }
.markdown-body table { border-spacing: 0; border-collapse: collapse; margin-bottom: 16px; width: 100%; }
.markdown-body table th, .markdown-body table td { padding: 6px 13px; border: 1px solid #30363d; }
.markdown-body table tr { background-color: #0d1117; border-top: 1px solid #21262d; }
.markdown-body table tr:nth-child(2n) { background-color: #161b22; }
.markdown-body a { color: #58a6ff; text-decoration: none; }
.markdown-body a:hover { text-decoration: underline; }
.markdown-body img { max-width: 100%; box-sizing: border-box; }
`;

const md = new MarkdownIt({
  html: true,
  linkify: true,
  typographer: false,
  highlight: function (str, lang) {
    if (lang && hljs.getLanguage(lang)) {
      try {
        return (
          '<pre class="hljs"><code>' +
          hljs.highlight(str, { language: lang, ignoreIllegals: true }).value +
          "</code></pre>"
        );
      } catch {
        // fall through to escape
      }
    }
    return '<pre class="hljs"><code>' + md.utils.escapeHtml(str) + "</code></pre>";
  },
});

const defaultFence =
  md.renderer.rules.fence ||
  function (tokens, idx, options, env, self) {
    return self.renderToken(tokens, idx, options);
  };

md.renderer.rules.fence = function (tokens, idx, options, env, self) {
  const token = tokens[idx];
  if (token.info.trim() === "mermaid") {
    return `<div class="mermaid">\n${token.content}</div>\n`;
  }
  return defaultFence(tokens, idx, options, env, self);
};

// Open external links in new tab
const defaultLinkOpen =
  md.renderer.rules.link_open ||
  function (tokens, idx, options, env, self) {
    return self.renderToken(tokens, idx, options);
  };

md.renderer.rules.link_open = function (tokens, idx, options, env, self) {
  const token = tokens[idx];
  const hrefIndex = token.attrIndex('href');
  if (hrefIndex >= 0) {
    const href = token.attrs[hrefIndex][1];
    if (href.startsWith('http://') || href.startsWith('https://')) {
      token.attrPush(['target', '_blank']);
    }
  }
  return defaultLinkOpen(tokens, idx, options, env, self);
};

const mdFilename = basename(mdFile);

async function renderMarkdown() {
  const input = await Bun.file(mdFile).text();
  return md.render(input);
}

function buildHtml(htmlContent) {
  return `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>${mdFilename}</title>
  <style>
  body {
    box-sizing: border-box;
    min-width: 200px;
    max-width: 980px;
    margin: 0 auto;
    padding: 45px;
  }
  @media (max-width: 767px) {
    body { padding: 15px; }
  }
  ${githubCss}
  </style>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ startOnLoad: true, theme: 'dark' });
  </script>
  <script>
    // Preserve scroll position across reloads
    window.addEventListener('beforeunload', () => {
      sessionStorage.setItem('scrollX', window.scrollX);
      sessionStorage.setItem('scrollY', window.scrollY);
    });

    window.addEventListener('load', () => {
      const scrollX = sessionStorage.getItem('scrollX');
      const scrollY = sessionStorage.getItem('scrollY');
      if (scrollX !== null && scrollY !== null) {
        window.scrollTo(parseInt(scrollX), parseInt(scrollY));
      }
    });

    // Connect to server for live reload
    const es = new EventSource('/events');
    es.addEventListener('reload', () => {
      location.reload();
    });
    es.onerror = () => {
      es.close();
    };
  </script>
</head>
<body class="markdown-body">
${htmlContent}
</body>
</html>`;
}

// Debug mode: just output HTML
if (debug) {
  try {
    const htmlContent = await renderMarkdown();
    console.log(buildHtml(htmlContent));
  } catch (err) {
    console.error(`Error: ${mdFile} not found or unreadable`);
    process.exit(1);
  }
  process.exit(0);
}

// Background ourselves if not already backgrounded
if (!process.env.MD_PREVIEW_BACKGROUNDED) {
  const browser = process.env.BROWSER;
  if (!browser) {
    console.error("Error: $BROWSER not set");
    process.exit(1);
  }

  const child = Bun.spawn([process.argv[0], process.argv[1], mdFile], {
    env: { ...process.env, MD_PREVIEW_BACKGROUNDED: "1" },
    stdin: "ignore",
    stdout: "pipe",
    stderr: "inherit",
    detached: true,
  });

  // Read the server URL from the child's output
  const reader = child.stdout.getReader();
  const decoder = new TextDecoder();
  let output = "";

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    output += decoder.decode(value);
    const match = output.match(/http:\/\/localhost:\d+/);
    if (match) {
      const url = match[0];
      console.log(`Opening ${mdFilename} in browser (server running in background)`);
      try {
        Bun.spawn([browser, url], {
          stdin: "ignore",
          stdout: "ignore",
          stderr: "ignore",
          detached: true,
        });
      } catch (err) {
        console.error(`Error: failed to launch browser: ${String(err)}`);
      }
      break;
    }
  }

  child.unref();
  process.exit(0);
}

// Live reload server
const clients = new Set();
let debounceTimer = null;

const server = Bun.serve({
  port: 0,
  idleTimeout: 0,
  async fetch(req) {
    const url = new URL(req.url);

    if (url.pathname === "/events") {
      // Server-Sent Events endpoint
      const signal = req.signal;
      let client = null;
      let keepalive = null;

      const stream = new ReadableStream({
        start(controller) {
          client = {
            send: (eventType, data) => {
              if (clients.has(client)) {
                try {
                  controller.enqueue(`event: ${eventType}\ndata: ${data}\n\n`);
                } catch {
                  client.close();
                }
              }
            },
            close: () => {
              if (clients.has(client)) {
                clients.delete(client);
                if (keepalive) clearInterval(keepalive);
                try {
                  controller.close();
                } catch {}
                checkShutdown();
              }
            }
          };

          clients.add(client);

          // Detect disconnect via abort signal
          signal.addEventListener('abort', () => {
            client.close();
          });

          // Send keepalive every 15 seconds
          keepalive = setInterval(() => {
            if (clients.has(client)) {
              try {
                controller.enqueue(": keepalive\n\n");
              } catch {
                clearInterval(keepalive);
                client.close();
              }
            } else {
              clearInterval(keepalive);
            }
          }, 15000);

          // Send initial connection message
          controller.enqueue("data: connected\n\n");
        },
        cancel() {
          if (client) client.close();
        }
      });

      return new Response(stream, {
        headers: {
          "Content-Type": "text/event-stream",
          "Cache-Control": "no-cache",
          "Connection": "keep-alive",
        },
      });
    }

    // Serve the HTML
    const htmlContent = await renderMarkdown();
    return new Response(buildHtml(htmlContent), {
      headers: { "Content-Type": "text/html" },
    });
  },
});

console.log(`Serving ${mdFilename} at http://localhost:${server.port}`);

// Watch for file changes
const watcher = watch(mdFile, (eventType) => {
  if (eventType === "change") {
    // Debounce rapid changes
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      // Notify all connected clients
      for (const client of clients) {
        client.send("reload", "");
      }
    }, 100);
  }
});

// Shutdown when no clients remain
let shutdownTimer = null;
function checkShutdown() {
  if (shutdownTimer) {
    clearTimeout(shutdownTimer);
    shutdownTimer = null;
  }

  if (clients.size === 0) {
    shutdownTimer = setTimeout(() => {
      if (clients.size === 0) {
        watcher.close();
        server.stop();
        process.exit(0);
      }
    }, 5000);
  }
}
